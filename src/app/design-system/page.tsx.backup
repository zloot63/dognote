import { type Config } from 'tailwindcss';
import { theme } from './src/styles/theme';

const config: Config = {
  content: [
    './src/pages/**/*.{js,ts,jsx,tsx,mdx}',
    './src/components/**/*.{js,ts,jsx,tsx,mdx}',
    './src/app/**/*.{js,ts,jsx,tsx,mdx}',
  ],
  darkMode: 'class', // 'class' 스트래티지 사용
  theme: {
    extend: {
      colors: theme.colors,
      spacing: theme.spacing,
      fontSize: theme.fontSize,
      borderRadius: theme.borderRadius,
      boxShadow: theme.boxShadow,
    },
  },
  plugins: [],
};

export default config;`}</code>
                </pre>
              </div>
              
              <h4 className="font-semibold mb-2">컴포넌트에서 다크모드 적용</h4>
              <div className="bg-neutral-50 p-4 rounded-lg mb-6">
                <pre className="text-sm text-neutral-700 overflow-x-auto">
                  <code>{`// 컴포넌트에서 다크모드 적용 예시
import { tw, createColorClass } from '@/lib/theme-utils';

function Card({ children, className = '', ...props }) {
  // 다크모드 클래스 적용
  const cardClasses = tw(
    'rounded-lg p-4',
    'bg-white border border-neutral-200 shadow-sm', // 라이트 모드 스타일
    'dark:bg-neutral-800 dark:border-neutral-700 dark:shadow-md', // 다크 모드 스타일
    className
  );
  
  return (
    <div className={cardClasses} {...props}>
      {children}
    </div>
  );
}

// 테마 유틸리티를 활용한 다크모드 클래스 생성
function Button({ variant = 'primary', children, ...props }) {
  // 변형별 다크모드 클래스 생성
  const variantClasses = {
    primary: tw(
      createColorClass('bg', 'primary', 600),
      createColorClass('text', 'white'),
      'hover:bg-primary-700',
      'dark:bg-primary-500 dark:hover:bg-primary-400'
    ),
    secondary: tw(
      createColorClass('bg', 'neutral', 200),
      createColorClass('text', 'neutral', 800),
      'hover:bg-neutral-300',
      'dark:bg-neutral-700 dark:text-neutral-200 dark:hover:bg-neutral-600'
    )
  };
  
  return (
    <button 
      className={tw('px-4 py-2 rounded-md', variantClasses[variant])} 
      {...props}
    >
      {children}
    </button>
  );
}`}</code>
                </pre>
              </div>
              
              <h4 className="font-semibold mb-2">다크모드 토글 컴포넌트</h4>
              <div className="bg-neutral-50 p-4 rounded-lg mb-6">
                <pre className="text-sm text-neutral-700 overflow-x-auto">
                  <code>{`// ThemeToggle.tsx
import { useState, useEffect } from 'react';
import { getCurrentThemeMode, applyThemeMode, ThemeMode } from '@/lib/theme-utils';

export function ThemeToggle() {
  const [mode, setMode] = useState<ThemeMode>('light');
  
  useEffect(() => {
    // 초기 모드 가져오기
    const initialMode = getCurrentThemeMode();
    setMode(initialMode);
    applyThemeMode(initialMode);
    
    // 시스템 설정 변경 감지
    const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
    const handleChange = () => {
      if (mode === 'system') {
        applyThemeMode('system');
      }
    };
    
    mediaQuery.addEventListener('change', handleChange);
    return () => mediaQuery.removeEventListener('change', handleChange);
  }, [mode]);
  
  const handleModeChange = (newMode: ThemeMode) => {
    setMode(newMode);
    applyThemeMode(newMode);
  };
  
  return (
    <div className="flex items-center space-x-2">
      <button
        onClick={() => handleModeChange('light')}
        className={tw(
          'p-2 rounded-md',
          mode === 'light' ? 'bg-primary-100 text-primary-700' : 'text-neutral-600'
        )}
        aria-label="라이트 모드"
      >
        <span>☀️</span>
      </button>
      
      <button
        onClick={() => handleModeChange('dark')}
        className={tw(
          'p-2 rounded-md',
          mode === 'dark' ? 'bg-primary-100 text-primary-700' : 'text-neutral-600'
        )}
        aria-label="다크 모드"
      >
        <span>🌙</span>
      </button>
      
      <button
        onClick={() => handleModeChange('system')}
        className={tw(
          'p-2 rounded-md',
          mode === 'system' ? 'bg-primary-100 text-primary-700' : 'text-neutral-600'
        )}
        aria-label="시스템 모드"
      >
        <span>💻</span>
      </button>
    </div>
  );
}`}</code>
                </pre>
              </div>
              
              <h4 className="font-semibold mb-2">반응형 테마 구현</h4>
              <div className="bg-neutral-50 p-4 rounded-lg mb-6">
                <pre className="text-sm text-neutral-700 overflow-x-auto">
                  <code>{`// 반응형 값 타입
type ResponsiveValue<T> = {
  'base'?: T;
  'sm'?: T;
  'md'?: T;
  'lg'?: T;
  'xl'?: T;
  '2xl'?: T;
};

// 반응형 값 해석
function resolveResponsiveValue<T>(
  value: T | ResponsiveValue<T>, 
  breakpoint: keyof ResponsiveValue<T> = 'base'
): T | undefined {
  if (typeof value === 'object' && value !== null) {
    // 현재 브레이크포인트에 대한 값이 있으면 사용
    if (value[breakpoint] !== undefined) {
      return value[breakpoint];
    }
    
    // 브레이크포인트 순서대로 확인
    const breakpoints: Array<keyof ResponsiveValue<T>> = ['base', 'sm', 'md', 'lg', 'xl', '2xl'];
    const index = breakpoints.indexOf(breakpoint);
    
    // 현재 브레이크포인트보다 작은 값을 찾음
    for (let i = index; i >= 0; i--) {
      const bp = breakpoints[i];
      if (value[bp] !== undefined) {
        return value[bp];
      }
    }
    
    return undefined;
  }
  
  // 반응형이 아닌 경우 그대로 반환
  return value;
}

// 반응형 Tailwind 클래스 생성
function createResponsiveClasses<T>(
  prefix: string,
  values: ResponsiveValue<T>
): string {
  const classes: string[] = [];
  
  // 기본값
  if (values.base !== undefined) {
    classes.push(`${prefix}-${values.base}`);
  }
  
  // 반응형 값
  if (values.sm !== undefined) classes.push(`sm:${prefix}-${values.sm}`);
  if (values.md !== undefined) classes.push(`md:${prefix}-${values.md}`);
  if (values.lg !== undefined) classes.push(`lg:${prefix}-${values.lg}`);
  if (values.xl !== undefined) classes.push(`xl:${prefix}-${values.xl}`);
  if (values['2xl'] !== undefined) classes.push(`2xl:${prefix}-${values['2xl']}`);
  
  return classes.join(' ');
}}`}</code>
                </pre>
              </div>
              
              <h4 className="font-semibold mb-2">반응형 컴포넌트 예시</h4>
              <div className="bg-neutral-50 p-4 rounded-lg mb-6">
                <pre className="text-sm text-neutral-700 overflow-x-auto">
                  <code>{`// 반응형 컴포넌트 예시
import { 
  createResponsiveClasses, 
  ResponsiveValue, 
  resolveResponsiveValue 
} from '@/lib/theme-utils';

type ContainerProps = {
  padding?: ResponsiveValue<number>;
  maxWidth?: ResponsiveValue<string>;
  children: React.ReactNode;
};

export function Container({ 
  padding = { 'base': 4, 'md': 6, 'lg': 8 },
  maxWidth = { 'base': 'full', 'md': '4xl', 'lg': '6xl' },
  children 
}: ContainerProps) {
  // 반응형 클래스 생성
  const paddingClasses = createResponsiveClasses('p', padding);
  const maxWidthClasses = createResponsiveClasses('max-w', maxWidth);
  
  const className = [
    'mx-auto w-full',
    paddingClasses,
    maxWidthClasses
  ].join(' ');
  
  return (
    <div className={className}>
      {children}
    </div>
  );
}

// 사용 예시
function Layout() {
  return (
    <Container
      padding={{ 'base': 4, 'md': 6, 'lg': 8 }}
      maxWidth={{ 'base': 'full', 'md': '4xl', 'lg': '6xl' }}
    >
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {/* 컴포넌트 내용 */}
      </div>
    </Container>
  );
}`}</code>
                </pre>
              </div>
              
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <div className="bg-green-50 p-4 rounded-lg border border-green-200">
                  <h4 className="font-medium text-green-800 mb-2">다크모드 구현 필수 요소</h4>
                  <ul className="list-disc pl-5 space-y-1 text-green-700">
                    <li>Tailwind 설정에 <code>darkMode: 'class'</code> 설정</li>
                    <li>사용자 선호 저장 (localStorage)</li>
                    <li>시스템 설정 감지 (prefers-color-scheme)</li>
                    <li>dark: 접두어를 사용한 스타일 정의</li>
                  </ul>
                </div>
                <div className="bg-purple-50 p-4 rounded-lg border border-purple-200">
