                      <td className="py-2 font-mono">createSpacingClass('p', 4)</td>
                    </tr>
                    <tr className="border-b border-neutral-100">
                      <td className="py-2 font-mono">createFontSizeClass</td>
                      <td className="py-2">폰트 크기 관련 Tailwind 클래스 생성</td>
                      <td className="py-2 font-mono">createFontSizeClass('lg')</td>
                    </tr>
                    <tr className="border-b border-neutral-100">
                      <td className="py-2 font-mono">createRadiusClass</td>
                      <td className="py-2">보더 반지름 관련 Tailwind 클래스 생성</td>
                      <td className="py-2 font-mono">createRadiusClass('rounded', 'md')</td>
                    </tr>
                    <tr className="border-b border-neutral-100">
                      <td className="py-2 font-mono">createShadowClass</td>
                      <td className="py-2">그림자 관련 Tailwind 클래스 생성</td>
                      <td className="py-2 font-mono">createShadowClass('lg')</td>
                    </tr>
                    <tr className="border-b border-neutral-100">
                      <td className="py-2 font-mono">createResponsiveClasses</td>
                      <td className="py-2">반응형 Tailwind 클래스 생성</td>
                      <td className="py-2 font-mono">createResponsiveClasses('p', { base: 4, md: 6 })</td>
                    </tr>
                  </tbody>
                </table>
              </div>
              
              <h4 className="font-semibold mb-2">Tailwind 클래스 생성 함수 사용 예시</h4>
              <div className="bg-neutral-50 p-4 rounded-lg mb-4">
                <pre className="text-sm text-neutral-700 overflow-x-auto">
                  <code>{`// Tailwind 클래스 생성 함수 사용 예시
import { 
  tw, 
  cx, 
  createColorClass, 
  createSpacingClass,
  createResponsiveClasses 
} from '@/lib/theme-utils';

// 조건부 클래스 생성
const buttonClasses = tw(
  'px-4 py-2 rounded-md font-medium transition-all',
  isDisabled && 'opacity-50 cursor-not-allowed',
  !isDisabled && 'hover:shadow-md'
);

// 클래스 결합
const cardClasses = cx(
  'rounded-lg shadow-md',
  variant === 'outlined' ? 'border border-neutral-200' : 'bg-white'
);

// 색상 클래스 생성
const bgClass = createColorClass('bg', 'primary', 600);  // 'bg-primary-600'
const textClass = createColorClass('text', 'error', 500); // 'text-error-500'

// 간격 클래스 생성
const paddingClass = createSpacingClass('p', 4);     // 'p-4'
const marginClass = createSpacingClass('mt', 6);     // 'mt-6'
const gapClass = createSpacingClass('gap', 2);       // 'gap-2'

// 반응형 클래스 생성
const responsivePadding = createResponsiveClasses('p', {
  'base': 4,
  'md': 6,
  'lg': 8
}); // 'p-4 md:p-6 lg:p-8'`}</code>
                </pre>
              </div>
              
              <h4 className="font-semibold mb-2">테마 설정과 Tailwind 통합 예시</h4>
