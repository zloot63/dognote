                <h4 className="font-medium text-blue-800 mb-2">모범 사례: 버튼 컴포넌트</h4>
                <p className="text-blue-700 mb-2">테마 유틸리티와 Tailwind를 함께 사용한 버튼 컴포넌트 예시:</p>
                <pre className="text-sm text-blue-700 bg-blue-50 overflow-x-auto">
                  <code>{`// Button.tsx
import { tw, cx, createColorClass } from '@/lib/theme-utils';

type ButtonProps = {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  children: React.ReactNode;
  // 기타 속성...
};

export function Button({ 
  variant = 'primary', 
  size = 'md', 
  disabled = false,
  children,
  ...props 
}: ButtonProps) {
  // 기본 클래스
  const baseClasses = 'rounded-md font-medium transition-all';
  
  // 크기별 클래스
  const sizeClasses = {
    sm: 'px-3 py-1.5 text-sm',
    md: 'px-4 py-2 text-base',
    lg: 'px-6 py-3 text-lg'
  };
  
  // 변형별 클래스
  const variantClasses = {
    primary: cx(
      createColorClass('bg', 'primary', 600),
      createColorClass('text', 'white'),
      'hover:bg-primary-700 shadow-sm'
    ),
    secondary: cx(
      createColorClass('bg', 'secondary', 500),
      createColorClass('text', 'white'),
      'hover:bg-secondary-600 shadow-sm'
    ),
    outline: cx(
      'border',
      createColorClass('border', 'primary', 600),
      createColorClass('text', 'primary', 600),
      'hover:bg-primary-50'
    ),
    ghost: cx(
      createColorClass('text', 'primary', 600),
      'hover:bg-primary-50'
    )
  };
  
  // 상태 클래스
  const stateClasses = {
    disabled: 'opacity-50 cursor-not-allowed pointer-events-none'
  };
  
  // 최종 클래스 결합
  const classes = tw(
    baseClasses,
    sizeClasses[size],
    variantClasses[variant],
    disabled && stateClasses.disabled
  );
  
  return (
    <button className={classes} disabled={disabled} {...props}>
      {children}
    </button>
  );
}`}</code>
                </pre>
              </div>
            </div>
          </div>
        );
        
      case 'theme-functions':
        return (
          <div className="space-y-8">
            <div>
              <h3 className="text-xl font-semibold mb-4">테마 유틸리티 함수</h3>
              <p className="mb-4">테마 유틸리티는 디자인 시스템의 값을 쉽게 사용할 수 있는 다양한 함수를 제공합니다:</p>
              
              <div className="overflow-x-auto mb-6">
