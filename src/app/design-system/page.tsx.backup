import { getColor, tw, createComponentClasses, animations, cn } from '@/lib/theme-utils';

// 색상 가져오기
const primaryColor = getColor('primary', 600); // '#4f46e5'

// Tailwind 클래스 생성
const bgClass = tw.bg.primary(500); // 'bg-primary-500'
const textClass = tw.text.neutral(700); // 'text-neutral-700'

// 조건부 클래스 결합
const className = cn(
  'p-4 rounded-lg',
  isActive && 'bg-primary-100',
  isDisabled && 'opacity-50 cursor-not-allowed'
);

// 컴포넌트 클래스 생성
const buttonClasses = createComponentClasses('button', 'primary', 'md');

// 애니메이션 적용
const animatedClass = cn('rounded-lg', animations.transition.normal, animations.hover.scale);`}</code>
