                    <tr className="border-b border-neutral-100">
                      <td className="py-2 font-mono">getVariantProps</td>
                      <td className="py-2">변형에 따른 props 가져오기</td>
                      <td className="py-2 font-mono">getVariantProps(variants, 'primary')</td>
                    </tr>
                  </tbody>
                </table>
              </div>
              
              <h4 className="font-semibold mb-2">컴포넌트 변형 생성 예시</h4>
              <div className="bg-neutral-50 p-4 rounded-lg mb-4">
                <pre className="text-sm text-neutral-700 overflow-x-auto">
                  <code>{`// 컴포넌트 변형 생성 예시
import { 
  createVariants, 
  createSizeVariants, 
  composeVariants,
  getVariantProps 
} from '@/lib/theme-utils';

// 버튼 변형 정의
const buttonVariants = createVariants({
  primary: {
    className: 'bg-primary-600 text-white hover:bg-primary-700',
    attributes: { role: 'button' }
  },
  secondary: {
    className: 'bg-secondary-500 text-white hover:bg-secondary-600',
    attributes: { role: 'button' }
  },
  outline: {
    className: 'border border-primary-600 text-primary-600 hover:bg-primary-50',
    attributes: { role: 'button' }
  },
  ghost: {
    className: 'text-primary-600 hover:bg-primary-50',
    attributes: { role: 'button' }
  }
});

// 버튼 크기 변형 정의
const buttonSizes = createSizeVariants({
  sm: { className: 'px-3 py-1.5 text-sm' },
  md: { className: 'px-4 py-2 text-base' },
  lg: { className: 'px-6 py-3 text-lg' }
});

// 버튼 상태 변형 정의
const buttonStates = createStateVariants({
  disabled: { 
    className: 'opacity-50 cursor-not-allowed pointer-events-none',
    attributes: { 'aria-disabled': 'true' }
  },
  loading: {
    className: 'opacity-80 cursor-wait',
    attributes: { 'aria-busy': 'true' }
  }
});

// 변형 합치기
const allButtonVariants = composeVariants(buttonVariants, buttonSizes, buttonStates);

// 특정 변형 사용
const primaryButtonProps = getVariantProps(buttonVariants, 'primary');
// { className: 'bg-primary-600 text-white hover:bg-primary-700', attributes: { role: 'button' } }

// 여러 변형 결합
const buttonProps = {
  ...getVariantProps(buttonVariants, 'primary'),
  ...getVariantProps(buttonSizes, 'md'),
  ...(isDisabled ? getVariantProps(buttonStates, 'disabled') : {})
};

// 결합된 클래스
const className = buttonProps.className; // 'bg-primary-600 text-white hover:bg-primary-700 px-4 py-2 text-base opacity-50 cursor-not-allowed pointer-events-none'

// 결합된 속성
const attributes = buttonProps.attributes; // { role: 'button', 'aria-disabled': 'true' }`}</code>
                </pre>
              </div>
              
              <h4 className="font-semibold mb-2">컴포넌트에서 변형 사용 예시</h4>
              <div className="bg-neutral-50 p-4 rounded-lg mb-6">
                <pre className="text-sm text-neutral-700 overflow-x-auto">
                  <code>{`// Button.tsx
import { 
  createVariants, 
  createSizeVariants, 
  createStateVariants,
  composeVariants,
  getVariantProps 
} from '@/lib/theme-utils';

type ButtonProps = {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  loading?: boolean;
  children: React.ReactNode;
  className?: string;
  // 기타 속성...
};

// 변형 정의
const buttonVariants = createVariants({
  primary: {
    className: 'bg-primary-600 text-white hover:bg-primary-700 shadow-sm',
    attributes: { role: 'button' }
  },
  secondary: {
    className: 'bg-secondary-500 text-white hover:bg-secondary-600 shadow-sm',
    attributes: { role: 'button' }
  },
  outline: {
    className: 'border border-primary-600 text-primary-600 hover:bg-primary-50',
    attributes: { role: 'button' }
  },
  ghost: {
    className: 'text-primary-600 hover:bg-primary-50',
    attributes: { role: 'button' }
  }
});

const buttonSizes = createSizeVariants({
  sm: { className: 'px-3 py-1.5 text-sm' },
  md: { className: 'px-4 py-2 text-base' },
  lg: { className: 'px-6 py-3 text-lg' }
});

const buttonStates = createStateVariants({
  disabled: { 
    className: 'opacity-50 cursor-not-allowed pointer-events-none',
    attributes: { 'aria-disabled': 'true' }
  },
  loading: {
    className: 'opacity-80 cursor-wait',
    attributes: { 'aria-busy': 'true' }
  }
});

export function Button({ 
  variant = 'primary', 
  size = 'md', 
  disabled = false,
  loading = false,
  children,
  className = '',
  ...props 
}: ButtonProps) {
  // 기본 클래스
  const baseClasses = 'rounded-md font-medium transition-all';
  
  // 변형 가져오기
  const variantProps = getVariantProps(buttonVariants, variant);
  const sizeProps = getVariantProps(buttonSizes, size);
  
  // 상태 처리
  const stateProps = disabled 
    ? getVariantProps(buttonStates, 'disabled')
    : loading 
      ? getVariantProps(buttonStates, 'loading')
      : {};
  
  // 클래스 결합
  const combinedClassName = [
    baseClasses,
    variantProps.className,
    sizeProps.className,
    stateProps.className,
    className
  ].filter(Boolean).join(' ');
  
  // 속성 결합
  const combinedAttributes = {
    ...variantProps.attributes,
    ...sizeProps.attributes,
    ...stateProps.attributes,
    disabled: disabled || loading
  };
  
  return (
    <button 
      className={combinedClassName} 
      {...combinedAttributes}
      {...props}
    >
      {loading && <span className="mr-2">⚪⚪⚪</span>}
      {children}
    </button>
  );
}`}</code>
                </pre>
              </div>
              
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <div className="bg-green-50 p-4 rounded-lg border border-green-200">
                  <h4 className="font-medium text-green-800 mb-2">변형 시스템의 장점</h4>
                  <ul className="list-disc pl-5 space-y-1 text-green-700">
                    <li>코드 재사용성 향상</li>
                    <li>중앙 관리로 일관성 보장</li>
                    <li>타입 안전성 및 자동완성</li>
                    <li>접근성 속성 자동 추가</li>
                  </ul>
                </div>
                <div className="bg-amber-50 p-4 rounded-lg border border-amber-200">
                  <h4 className="font-medium text-amber-800 mb-2">사용 패턴</h4>
                  <ul className="list-disc pl-5 space-y-1 text-amber-700">
                    <li>변형을 모듈로 분리하여 정의</li>
                    <li>필요한 변형만 합치기</li>
                    <li>기본값 설정으로 사용성 향상</li>
                    <li>상태에 따른 조건부 적용</li>
                  </ul>
                </div>
              </div>
              
              <div className="bg-blue-50 p-4 rounded-lg border border-blue-200">
                <h4 className="font-medium text-blue-800 mb-2">변형 시스템 확장</h4>
                <p className="text-blue-700 mb-2">테마 유틸리티를 활용한 사용자 정의 변형 시스템 확장 예시:</p>
                <pre className="text-sm text-blue-700 bg-blue-50 overflow-x-auto">
                  <code>{`// 사용자 정의 변형 시스템 확장

// 카드 컴포넌트를 위한 변형 정의
const cardVariants = createVariants({
  default: {
    className: 'bg-white border border-neutral-200 shadow-sm',
    attributes: { role: 'region' }
  },
  elevated: {
    className: 'bg-white border border-neutral-100 shadow-md',
    attributes: { role: 'region' }
  },
  flat: {
    className: 'bg-neutral-50 border border-neutral-200',
    attributes: { role: 'region' }
  },
  colorful: {
    className: 'bg-gradient-to-br from-primary-50 to-secondary-50 border border-primary-100',
    attributes: { role: 'region' }
  }
});

// 카드 크기 변형
const cardSizes = createSizeVariants({
  sm: { className: 'p-3 text-sm' },
  md: { className: 'p-5 text-base' },
  lg: { className: 'p-7 text-lg' }
});

// 카드 상태 변형
const cardStates = createStateVariants({
  interactive: { 
    className: 'cursor-pointer hover:shadow-md transition-shadow',
    attributes: { tabIndex: '0' }
  },
  disabled: { 
    className: 'opacity-60 pointer-events-none',
    attributes: { 'aria-disabled': 'true' }
  }
});

// 변형 합치기 및 사용
function Card({ 
  variant = 'default', 
  size = 'md',
  interactive = false,
  disabled = false,
  children,
  ...props 
}) {
  const variantProps = getVariantProps(cardVariants, variant);
  const sizeProps = getVariantProps(cardSizes, size);
  
  const stateProps = disabled 
    ? getVariantProps(cardStates, 'disabled')
    : interactive 
      ? getVariantProps(cardStates, 'interactive')
      : {};
  
  const className = [
    'rounded-lg',
    variantProps.className,
    sizeProps.className,
    stateProps.className
  ].filter(Boolean).join(' ');
  
  return (
    <div 
      className={className}
      {...variantProps.attributes}
      {...sizeProps.attributes}
      {...stateProps.attributes}
      {...props}
    >
      {children}
    </div>
  );
}`}</code>
                </pre>
              </div>
            </div>
          </div>
        );
        
      case 'theme-tailwind':
