                    <tr className="border-b border-neutral-100">
                      <td className="py-2 font-mono">getFontSizeValue</td>
                      <td className="py-2">폰트 크기 키에 대한 값 반환</td>
                      <td className="py-2 font-mono">getFontSizeValue('lg')</td>
                    </tr>
                    <tr className="border-b border-neutral-100">
                      <td className="py-2 font-mono">getRadiusValue</td>
                      <td className="py-2">보더 반지름 키에 대한 값 반환</td>
                      <td className="py-2 font-mono">getRadiusValue('md')</td>
                    </tr>
                    <tr className="border-b border-neutral-100">
                      <td className="py-2 font-mono">getShadowValue</td>
                      <td className="py-2">그림자 키에 대한 CSS 그림자 값 반환</td>
                      <td className="py-2 font-mono">getShadowValue('lg')</td>
                    </tr>
                    <tr className="border-b border-neutral-100">
                      <td className="py-2 font-mono">createCSSVariables</td>
                      <td className="py-2">테마 값에서 CSS 변수 생성</td>
                      <td className="py-2 font-mono">createCSSVariables(theme)</td>
                    </tr>
                    <tr className="border-b border-neutral-100">
                      <td className="py-2 font-mono">resolveResponsiveValue</td>
                      <td className="py-2">반응형 값 해석</td>
                      <td className="py-2 font-mono">resolveResponsiveValue(value, 'md')</td>
                    </tr>
                    <tr className="border-b border-neutral-100">
                      <td className="py-2 font-mono">resolveThemeValue</td>
                      <td className="py-2">현재 테마 모드에 따라 값 해석</td>
                      <td className="py-2 font-mono">resolveThemeValue(value, 'dark')</td>
                    </tr>
                  </tbody>
                </table>
              </div>
              
              <h4 className="font-semibold mb-2">테마 함수 사용 예시</h4>
              <div className="bg-neutral-50 p-4 rounded-lg mb-4">
                <pre className="text-sm text-neutral-700 overflow-x-auto">
                  <code>{`// 테마 함수 사용 예시
import { 
  getColorValue, 
  getSpacingValue, 
  getFontSizeValue, 
  getRadiusValue,
  getShadowValue 
} from '@/lib/theme-utils';

// 색상 값 가져오기
const primaryColor = getColorValue('primary', 600); // #4f46e5
const errorColor = getColorValue('error', 500);     // #ef4444

// 간격 값 가져오기
const spacing = getSpacingValue(4);  // 16px
const gutter = getSpacingValue(6);   // 24px

// 폰트 크기 값 가져오기
const textSize = getFontSizeValue('lg');  // 1.125rem

// 반지름 값 가져오기
const radius = getRadiusValue('md');  // 0.375rem

// 그림자 값 가져오기
const shadow = getShadowValue('lg');  // 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)

// 반응형 값 해석
const responsivePadding = resolveResponsiveValue({
  base: 4,
  md: 6,
  lg: 8
}, 'md'); // 현재 화면 크기가 'md' 범위일 때 6 반환

// 테마 모드에 따른 값 해석
const bgColor = resolveThemeValue({
  light: '#ffffff',
  dark: '#121212'
}, 'light'); // 현재 테마가 'light'일 때 '#ffffff' 반환`}</code>
                </pre>
