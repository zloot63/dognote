rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 사용자 문서 - 본인만 읽기/쓰기 가능
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 강아지 문서 - 소유자만 읽기/쓰기 가능
    match /dogs/{dogId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // 건강 기록 - 강아지 소유자만 접근 가능
    match /dogs/{dogId}/healthRecords/{recordId} {
      allow read, write: if request.auth != null && 
        request.auth.uid == get(/databases/$(database)/documents/dogs/$(dogId)).data.userId;
      allow create: if request.auth != null && 
        request.auth.uid == get(/databases/$(database)/documents/dogs/$(dogId)).data.userId;
    }

    // 산책 기록 - 강아지 소유자만 접근 가능
    match /dogs/{dogId}/walkRecords/{recordId} {
      allow read, write: if request.auth != null && 
        request.auth.uid == get(/databases/$(database)/documents/dogs/$(dogId)).data.userId;
      allow create: if request.auth != null && 
        request.auth.uid == get(/databases/$(database)/documents/dogs/$(dogId)).data.userId;
    }

    // 예방접종 기록 - 강아지 소유자만 접근 가능
    match /dogs/{dogId}/vaccinations/{vaccinationId} {
      allow read, write: if request.auth != null && 
        request.auth.uid == get(/databases/$(database)/documents/dogs/$(dogId)).data.userId;
      allow create: if request.auth != null && 
        request.auth.uid == get(/databases/$(database)/documents/dogs/$(dogId)).data.userId;
    }

    // 개발 환경에서만 임시로 모든 접근 허용 (프로덕션에서는 제거)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}